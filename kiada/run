#!/usr/bin/env bash

set -euox pipefail

THIS_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"


start() {
	uv run -- uvicorn 'main:app' --host 0.0.0.0 --port 8080 --reload
}

docker-start:dev() {
	# docker run -p 8080:8080 kiada:latest

	# remove the container if it exists
	# docker rm -f kiada 2>/dev/null || true

	# # run the container
	# docker run --rm --name kiada \
	# 	--publish 8080:8080 \
	# 	--volume "${THIS_DIR}/static:/app/static" \
	# 	--volume "${THIS_DIR}/templates:/app/templates" \
	# 	--volume "${THIS_DIR}/main.py:/app/main.py" \
	# 	--volume "${THIS_DIR}/pyproject.toml:/app/pyproject.toml" \
	# 	--volume "${THIS_DIR}/README.md:/app/README.md" \
	# 	--volume "${THIS_DIR}/uv.lock:/app/uv.lock" \
	# 	--volume "${THIS_DIR}/run:/app/run" \
	# 	kiada:latest

	docker compose up --build --remove-orphans
}

docker-build() {
	docker build -t kiada:latest .
}

# remove all files generated by tests, builds, or operating this codebase
clean() {
	set -x

	rm -rf dist build coverage.xml test-reports/
	find . \
	  -type d \
	  \( \
		-name "*cache*" \
		-o -name "*.dist-info" \
		-o -name "*.egg-info" \
		-o -name "*htmlcov" \
        -o -name "cdk.out" \
	  \) \
	  -not -path "*env*/*" \
	  -exec rm -r {} + || true

	find . \
	  -type f \
	  -name "*.pyc" \
	  -not -path "*env/*" \
	  -exec rm {} +
}


# print all functions in this file
help() {
    echo "$0 <task> <args>"
    echo "Tasks:"
    compgen -A function | cat -n
}


TIMEFORMAT="Task completed in %3lR"
time ${@:-help}
