// hover over or get autocompletion for the settings keys in this file to learn about what they do
{
    "editor.rulers": [
        {
            "column": 99,
            "color": "gray"
        },
        {
            "column": 119,
            "color": "purple"
        }
    ],
    "editor.formatOnSave": true,
    "python.testing.pytestArgs": ["${workspaceFolder}/kiada/tests"],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "testing.defaultGutterClickAction": "debug",
    "python.analysis.inlayHints.pytestParameters": true,
    "python.defaultInterpreterPath": "${workspaceFolder}/kiada/.venv/bin/python",
    // https://github.com/astral-sh/ruff-vscode
    "editor.defaultFormatter": "charliermarsh.ruff",
    "ruff.configuration": "${workspaceFolder}/kiada/pyproject.toml",
    "ruff.organizeImports": true,
    // notebook settings
    "notebook.formatOnSave.enabled": true,
    "notebook.lineNumbers": "on",
    "notebook.codeActionsOnSave": {
        "notebook.source.fixAll": "explicit",
        "notebook.source.organizeImports": "explicit"
    },
    // .py settings
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        },
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "python.analysis.autoImportCompletions": true,
    "python.analysis.indexing": true,
    "python.languageServer": "None",
    "python.analysis.completeFunctionParens": true,
    // Cursor specific settings
    "cursorpyright.analysis.autoImportCompletions": true,
    "basedpyright.analysis.autoImportCompletions": true,
    "basedpyright.analysis.typeCheckingMode": "off",
    "basedpyright.analysis.inlayHints.callArgumentNames": false,
    "basedpyright.analysis.inlayHints.callArgumentNamesMatching": false,
    "basedpyright.analysis.inlayHints.variableTypes": false,
    "basedpyright.analysis.inlayHints.genericTypes": false,
    "basedpyright.analysis.inlayHints.functionReturnTypes": false,
}
